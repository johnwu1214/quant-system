def log_decision(action, code, price, shares, score, reason, market, result="pending"):
    """追加记录到 decision_log.jsonl"""
    try:
        record = {
            "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "action": action,
            "code": code,
            "price": round(price, 3),
            "shares": shares,
            "score": round(score, 1) if score else None,
            "reason": reason,
            "market": market,
            "result": result
        }
        with open(DECISION_LOG, "a", encoding="utf-8") as f:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
        logger.info(f"[DECISION] {action} {code}@{price} result={result}")
    except Exception as e:
        logger.error(f"[DECISION] 记录失败: {e}")

def get_market_status():
    """获取大盘状态：strong/weak/neutral"""
    if not HAS_AKSHARE:
        return "unknown"
    try:
        df = ak.stock_zh_index_daily(symbol="sh000300")
        if len(df) < 25:
            return "unknown"
        prices = df["close"].values[-25:]
        ma20 = np.mean(prices[:-1])
        current = prices[-1]
        ratio = current / ma20 if ma20 > 0 else 1.0
        if ratio >= 1.02:
            return "strong"
        elif ratio <= 0.98:
            return "weak"
        else:
            return "neutral"
    except Exception as e:
        logger.warning(f"[MARKET] 大盘状态获取失败: {e}")
        return "unknown"

def check_market_filter():
    """大盘过滤器：MA20 × 0.98 作为买入条件
    返回: (允许买入, 大盘状态描述)
    """
    if not HAS_AKSHARE:
        logger.warning("[MARKET] AKShare未安装，跳过大盘过滤")
        return True, "AKShare未安装"
    try:
        df = ak.stock_zh_index_daily(symbol="sh000300")
        if len(df) < 21:
            logger.warning(f"[MARKET] 沪深300数据不足({len(df)}条)，跳过过滤")
            return True, f"数据不足({len(df)}条)"
        prices = df["close"].values[-21:]
        ma20 = np.mean(prices[:-1])
        current = prices[-1]
        ratio = current / ma20 if ma20 > 0 else 1.0
        logger.info(f"[MARKET] 沪深300: 现价{current:.2f} MA20={ma20:.2f} 比值={ratio:.4f}")
        if current < ma20 * 0.98:
            return False, f"大盘偏弱(现价{current:.2f}<MA20×0.98={ma20*0.98:.2f})"
        return True, f"大盘正常(现价{current:.2f}>=MA20×0.98={ma20*0.98:.2f})"
    except Exception as e:
        logger.error(f"[MARKET] 大盘过滤检查失败: {e}")
        return True, f"检查失败: {e}"

