def daily_check():
    """每日交易检查"""
    state = load_portfolio()
    today = datetime.now().strftime("%Y-%m-%d")
    logger.info(f"\n{'='*50}\n开始每日检查 {today}\n{'='*50}")

    # 初始化每日买入计数器（任务4修复）
    daily_buy_count = 0

    # ── 步骤1：大盘过滤器检查（任务3） ──
    market_ok, market_desc = check_market_filter()
    logger.info(f"[大盘] {market_desc}")

    # ── 步骤2：处理现有持仓 ──
    held = list(state.get("positions", {}).keys())
    logger.info(f"[持仓] {len(held)}只: {held}")
    for code in list(held):
        pos = state["positions"][code]
        price = get_realtime_price(code)
        if price is None or price <= 0:
            logger.warning(f"[{code}] 无法获取价格，跳过")
            continue

        # 更新当前价
        pos["current_price"] = price

        # 计算盈亏
        cost = pos["cost"]
        pnl_pct = (price - cost) / cost * 100
        logger.info(f"[{code}] 现价:{price:.2f} 成本:{cost:.2f} 盈亏:{pnl_pct:.2f}%")

        # ── 移动止盈检查（任务1） ──
        trailing_triggered, trailing_reason = check_trailing_stop(state, code, price)
        if trailing_triggered:
            logger.info(f"[{code}] 触发移动止盈: {trailing_reason}")
            remove_position(state, code, price, reason=trailing_reason, result="trailing_stop_win")
            continue

        # ── 止损检查 ──
        atr_stop = get_atr_stop(code, cost)
        hard_stop = cost * 0.92
        stop_price = max(hard_stop, atr_stop)
        if price <= stop_price:
            reason = f"止损: ATR/硬止损触发 现价{price:.2f}<=止损价{stop_price:.2f}"
            logger.info(f"[{code}] {reason}")
            remove_position(state, code, price, reason=reason, result="stop_loss")
            blacklist_manager.add_to_blacklist(code)
            continue

        # ── 卖出信号检查 ──
        klines = get_history_kline(code)
        if klines is None or len(klines) < MIN_KLINE_REQUIRED:
            logger.warning(f"[{code}] K线不足({len(klines) if klines else 0}根)，跳过")
            continue
        prices_list = [float(k["close"]) for k in klines]
        sig = compute_signal(code, prices_list, price)
        logger.info(f"[{code}] 信号评分={sig['score']} 信号={sig['signal']} 原因:{sig['reason']}")
        if sig["signal"] == "SELL" and sig["score"] <= SELL_THRESHOLD:
            reason = f"信号评分{sig['score']}<={SELL_THRESHOLD} 原因:{sig['reason']}"
            logger.info(f"[{code}] 卖出信号: {reason}")
            remove_position(state, code, price, reason=reason, result="signal_sell")
            continue

        # 更新持仓信息（保存high_water_mark）
        save_portfolio(state)

    # ── 步骤3：买入候选（仅在大盘过滤器通过时） ──
    if market_ok:
        watch_list = load_watch_list()
        available = [c for c in watch_list if c not in held]

        # 排序：优先考虑因子得分高的
        candidates = []
        for code in available:
            # 黑名单检查
            if RISK_LOADED and blacklist_manager.is_blacklisted(code):
                logger.info(f"[{code}] 在黑名单中，跳过")
                continue
            # 价格获取
            price = get_realtime_price(code)
            if price is None or price <= 0:
                continue
            # K线检查
            klines = get_history_kline(code)
            if klines is None or len(klines) < MIN_KLINE_REQUIRED:
                continue
            prices_list = [float(k["close"]) for k in klines]
            sig = compute_signal(code, prices_list, price)
            candidates.append((code, price, sig))

        # 按分数排序
        candidates.sort(key=lambda x: x[2]["score"], reverse=True)
        logger.info(f"[候选] {len(candidates)}只: {[(c[0],c[2]['score']) for c in candidates[:5]]}")

        # 每日买入限制（任务4）
        for code, price, sig in candidates:
            if daily_buy_count >= MAX_DAILY_BUY:
                logger.info(f"[买入限制] 今日已达MAX_DAILY_BUY={MAX_DAILY_BUY}，停止买入")
                break
            if len(state["positions"]) >= MAX_POSITIONS:
                logger.info(f"[仓位] 已达上限MAX_POSITIONS={MAX_POSITIONS}")
                break
            total_value = sum(p["shares"] * p["current_price"] for p in state["positions"].values())
            if total_value / (state["cash"] + total_value) >= MAX_POSITION_RATIO:
                logger.info(f"[仓位] 总仓位已满({MAX_POSITION_RATIO*100:.0f}%)")
                break

            # 执行买入
            shares = int((state["cash"] * sig["position_pct"]) / price / 100) * 100
            if shares < 100:
                logger.info(f"[{code}] 资金不足买入最小单位")
                continue
            reason = f"{sig['reason']} 信号评分{sig['score']} 档位:{sig['tier']}"
            if add_position(state, code, shares, price, sig["score"], reason, market_desc):
                daily_buy_count += 1
    else:
        logger.info(f"[买入限制] 大盘偏弱，暂停买入: {market_desc}")

    save_portfolio(state)
    total = sum(p["shares"] * p["current_price"] for p in state["positions"].values())
    logger.info(f"\n检查完成 | 现金:{state['cash']:.2f} | 持仓:{total:.2f} | 总资产:{state['cash']+total:.2f}")

if __name__ == "__main__":
    daily_check()
