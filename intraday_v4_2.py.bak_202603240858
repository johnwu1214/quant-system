def load_portfolio():
    with open(PORTFOLIO_FILE, encoding="utf-8") as f:
        return json.load(f)

def save_portfolio(state):
    state["updated_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(PORTFOLIO_FILE, "w", encoding="utf-8") as f:
        json.dump(state, f, ensure_ascii=False, indent=2)

def add_position(state, code, shares, price, score=0, reason="", market="unknown"):
    """买入持仓（已包含decision_log记录）"""
    amount = round(shares * price, 2)
    if state["cash"] < amount:
        logger.warning(f"现金不足，无法买入 {code}")
        return False
    state["cash"] = round(state["cash"] - amount, 2)
    state.setdefault("positions", {})[code] = {
        "shares": shares,
        "cost": round(price, 3),
        "current_price": price,
        "high_water_mark": price,  # 记录买入价为初始高点
        "entry_time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    }
    state.setdefault("trades", []).append({
        "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "action": "BUY", "code": code,
        "shares": shares, "price": price, "amount": amount
    })
    save_portfolio(state)
    # 记录decision_log
    log_decision("BUY", code, price, shares, score, reason, market, "pending")
    logger.info(f"买入 {code}: {shares}股 @ {price}，花费 {amount}")
    return True

def remove_position(state, code, price, reason="信号卖出", result="pending"):
    """卖出持仓（已包含decision_log记录）"""
    pos = state.get("positions", {}).get(code)
    if not pos:
        return False
    shares = pos["shares"]
    cost   = pos["cost"]
    amount = round(shares * price, 2)
    pnl    = round((price - cost) * shares, 2)
    pnl_pct= round((price - cost) / cost * 100, 2)
    state["cash"] = round(state["cash"] + amount, 2)
    del state["positions"][code]
    state.setdefault("trades", []).append({
        "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "action": "SELL", "code": code,
        "shares": shares, "price": price,
        "amount": amount, "pnl": pnl,
        "pnl_pct": pnl_pct, "reason": reason
    })
    save_portfolio(state)
    # 记录decision_log
    log_decision("SELL", code, price, shares, 0, reason, "unknown", result)
    emoji = "盈利" if pnl >= 0 else "亏损"
    logger.info(f"卖出 {code}: {shares}股 @ {price}，{emoji} {pnl}({pnl_pct}%) 原因:{reason}")
    return True

