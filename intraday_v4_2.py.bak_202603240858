# 移动止盈检查
# ══════════════════════════════════════════════════════
def check_trailing_stop(state, code, current_price):
    """
    检查移动止盈条件
    返回: (是否触发止盈, 止盈原因)
    """
    pos = state.get("positions", {}).get(code)
    if not pos:
        return False, ""

    entry_price = pos["cost"]
    high_water = pos.get("high_water_mark", entry_price)

    # 更新历史最高价
    if current_price > high_water:
        pos["high_water_mark"] = current_price
        save_portfolio(state)

    profit_pct = (current_price - entry_price) / entry_price

    # 检查各档止盈
    if profit_pct >= TRAILING_CONFIG["40"]["profit"]:
        threshold = high_water * (1 - TRAILING_CONFIG["40"]["drawdown"])

    # 检查各档止盈
    if profit_pct >= TRAILING_CONFIG["40"]["profit"]:
        threshold = high_water * (1 - TRAILING_CONFIG["40"]["drawdown"])
        if current_price < threshold:
            return True, f"移动止盈(40%档): 现价{current_price:.2f}<回撤阈值{threshold:.2f}(回撤{TRAILING_CONFIG['40']['drawdown']*100:.0f}%)"
    elif profit_pct >= TRAILING_CONFIG["25"]["profit"]:
        threshold = high_water * (1 - TRAILING_CONFIG["25"]["drawdown"])
        if current_price < threshold:
            return True, f"移动止盈(25%档): 现价{current_price:.2f}<回撤阈值{threshold:.2f}(回撤{TRAILING_CONFIG['25']['drawdown']*100:.0f}%)"
    elif profit_pct >= TRAILING_CONFIG["15"]["profit"]:
        threshold = high_water * (1 - TRAILING_CONFIG["15"]["drawdown"])
        if current_price < threshold:
            return True, f"移动止盈(15%档): 现价{current_price:.2f}<回撤阈值{threshold:.2f}(回撤{TRAILING_CONFIG['15']['drawdown']*100:.0f}%)"

    return False, ""

def get_atr_stop(code, entry_price, multiplier=3.0):
    """计算ATR止损位"""
    prices = get_history_kline(code, 14)
    if prices is None or len(prices) < 14:
        return entry_price * 0.92
    tr_list = []
    for i in range(1, len(prices)):
        high = float(prices[i]["high"])
        low  = float(prices[i]["low"])
        prev = float(prices[i-1]["close"])
        tr = max(high - low, abs(high - prev), abs(low - prev))
        tr_list.append(tr)
    atr = np.mean(tr_list[-14:])
    stop = entry_price - multiplier * atr
    logger.info(f"[{code}] ATR={atr:.2f} 止损位={stop:.2f}({multiplier}x)")
    return stop

