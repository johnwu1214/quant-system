def get_realtime_price(code):
    return _dm_price(code)

def get_history_kline(code, days=60):
    return _dm_kline(code, days)

def calc_rsi(prices, period=14):
    if len(prices) < period + 1:
        return 50.0
    deltas = np.diff(prices[-(period+1):])
    gains  = np.where(deltas > 0, deltas, 0)
    losses = np.where(deltas < 0, -deltas, 0)
    avg_g, avg_l = gains.mean(), losses.mean()
    if avg_l == 0:
        return 100.0
    return round(100 - 100 / (1 + avg_g / avg_l), 1)

def calc_ema(prices, period):
    if len(prices) < period:
        return float(prices[-1])
    k, ema = 2 / (period + 1), float(prices[-period])
    for p in prices[-period+1:]:
        ema = p * k + ema * (1 - k)
    return ema

def calc_macd_diff(prices):
    if len(prices) < 26:
        return 0.0
    return calc_ema(prices, 12) - calc_ema(prices, 26)

def compute_signal(code, prices_list, current_price):
    prices  = np.array(prices_list, dtype=float)
    score   = 50.0
    breakdown     = {}
    has_conflict  = False
    conflict_desc = ""

    # RSI
    rsi = calc_rsi(prices)
    rsi_extreme = False
    if rsi <= RSI_EXTREME_OVERSOLD:
        rs, rd, rsi_extreme = 30, f"RSI={rsi:.0f}极端超卖(+30)", True
    elif rsi < 35:
        rs, rd = 25, f"RSI={rsi:.0f}超卖(+25)"
    elif rsi > RSI_EXTREME_OVERBOUGHT:
        rs, rd, rsi_extreme = -30, f"RSI={rsi:.0f}极端超买(-30)", True
    elif rsi > 65:
        rs, rd = -25, f"RSI={rsi:.0f}超买(-25)"
    else:
        rs, rd = 0, f"RSI={rsi:.0f}中性"
    breakdown["rsi"] = {"score": rs, "desc": rd, "extreme": rsi_extreme}
    score += rs

    # MACD
    macd_up = calc_macd_diff(prices) > 0
    ms = 15 if macd_up else -15
    md = "MACD金叉(+15)" if macd_up else "MACD死叉(-15)"
    breakdown["macd"] = {"score": ms, "desc": md}
    score += ms

    # MA20
    ma20 = np.mean(prices[-20:]) if len(prices) >= 20 else current_price
    dev  = (current_price - ma20) / ma20
    if dev < -0.05:
        mas, mad = 10, f"低于MA20 {abs(dev)*100:.1f}%(+10)"
    elif dev > 0.05:
        mas, mad = -10, f"高于MA20 {dev*100:.1f}%(-10)"
    else:
        mas, mad = 0, "价格在MA20附近"
    breakdown["ma20"] = {"score": mas, "desc": mad}
    score += mas

    # 矛盾检测
    rsi_bull = rs > 0
    rsi_bear = rs < 0
    if rsi_bull and not macd_up:
        has_conflict  = True
        conflict_desc = "RSI极端超卖+MACD死叉→维持8%仓位" if rsi_extreme else "RSI超卖+MACD死叉→降至4%仓位"
    elif rsi_bear and macd_up:
        has_conflict  = True
        conflict_desc = "RSI极端超买+MACD金叉→维持8%仓位" if rsi_extreme else "RSI超买+MACD金叉→降至4%仓位"

    # Qlib因子得分加成（0-20分）
    factor_bonus = _FACTOR_SCORES.get(code, 0)
    if factor_bonus > 0:
        breakdown["qlib"] = {
            "score": factor_bonus,
            "desc":  f"Qlib因子加成+{factor_bonus:.1f}"
        }
        score += factor_bonus

    score  = round(max(0, min(100, score)), 1)
    signal = "BUY" if score >= BUY_THRESHOLD else ("SELL" if score <= SELL_THRESHOLD else "HOLD")
    tier   = "HIGH" if not has_conflict else ("MEDIUM" if rsi_extreme else "LOW")
    pos_pct= POSITION_SIZES[tier] if signal != "HOLD" else 0.0
    reason = " | ".join(v["desc"] for v in breakdown.values() if v.get("score", 0) != 0) or "各因子中性"

    return {
        "symbol": code, "score": score, "signal": signal,
        "tier": tier, "position_pct": pos_pct,
        "has_conflict": has_conflict, "conflict_desc": conflict_desc,
        "factor_bonus": factor_bonus,
        "reason": reason
    }

